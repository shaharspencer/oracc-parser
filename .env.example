# ===========================================================================
# oracc-parser Configuration
# ===========================================================================
# Copy this file to .env and adjust values as needed.
#
# The .env file is loaded automatically when you import oracc_parser or
# run the CLI. You can also set these as environment variables directly.
#
# By default, oracc-parser automatically detects the repo root by walking
# up from the current directory and looking for pyproject.toml.
# All data-related directories default to <repo_root>/data/.
# ===========================================================================

# --- Data Sources ---
# Zenodo record URL for pre-downloaded heavy data.
ORACC_ZENODO_RECORD_URL=https://zenodo.org/records/18643122

# --- Directories ---
# Root directory for all data (downloads, cache, translations).
# Leave blank to use auto-detected <repo_root>/data
ORACC_DATA_DIR=

# Root directory for user-facing exports (CSV, JSONL).
# Leave blank to use auto-detected <repo_root>/output
ORACC_OUTPUT_DIR=

# Override individual sub-directories (optional):
# Default: ORACC_DATA_DIR/cache
ORACC_CACHE_DIR=

# Default: ORACC_DATA_DIR/jsonzip
ORACC_JSONZIP_DIR=

# --- Cache Settings ---
# If true, use locally cached tablet parse results (much faster on repeat runs).
ORACC_USE_CACHE=true

# --- Pleiades ---
# Path to pre-downloaded Pleiades ZIP (from Zenodo).
# If set, the parser uses this instead of hitting pleiades.stoa.org.
ORACC_PLEIADES_ZIP=

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
ORACC_LOG_LEVEL=INFO
